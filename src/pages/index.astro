---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Timeline planner for a Toronto to Halifax trip from July 23 to August 2, 2026."
    />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    />
    <script
      is:inline
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      defer
    ></script>
    <title>Trip Planner</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label="Trip Planner home">
        Trip Planner
      </a>
      <nav aria-label="Primary navigation">
        <a href={withBase("/")} aria-current="page">Plan</a>
        <a href={withBase("/places/")}>Places</a>
        <a href={withBase("/food/")}>Food</a>
      </nav>
    </header>

    <main class="planner-page">
      <section class="page-hero planner-hero">
        <div>
          <h1>
            <span>Trip to Atlantic Canada</span>
          </h1>
          <p>
            A compact plan for the Atlantic Canada trip, with the route, daily
            schedule, and packing checklist in one place.
          </p>
        </div>
      </section>

      <section class="map-section planner-map-section" aria-label="Map of Atlantic Canada trip area">
        <div class="map-shell">
          <div id="trip-map" aria-label="Map showing today's planned trip base"></div>
        </div>
      </section>

      <section class="section after-map-section timeline-section" id="timeline" aria-label="Trip timeline">
        <div class="section-header">
          <h2>Timeline</h2>
        </div>
        <ol class="timeline trip-timeline">
          {timeline.map((item) => (
            <li>
              <time>{item.date}</time>
              <div>
                <div class="timeline-title-row">
                  <h3>{item.title}</h3>
                </div>
                <ul>
                  {item.details.map((detail) => <li>{detail}</li>)}
                </ul>
                {(item.places.length > 0 || item.foods.length > 0) && (
                  <div class="timeline-place-links" aria-label={`Links for ${item.date}`}>
                    {item.places.map((place) => (
                      <a href={placeHref(place)}>{placeLabels[place] ?? place}</a>
                    ))}
                    {item.foods.map((food) => (
                      <a href={foodHref(food)}>{food}</a>
                    ))}
                  </div>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>

      <section class="section packing-section" id="packing" aria-label="Packing list">
        <div class="section-header">
          <h2>Packing list</h2>
        </div>
        <div class="packing-grid">
          {packingGroups.map((group) => (
            <section class="packing-group" aria-labelledby={`packing-${slugify(group.title)}`}>
              <h3 id={`packing-${slugify(group.title)}`}>{group.title}</h3>
              <ul>
                {group.items.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          ))}
        </div>
      </section>

    </main>
    <footer class="site-footer">
      <a href="https://github.com/jacksoncurrie/atlantic-trip-planner">Trip Planner</a>{" "}
      made by{" "}
      <a href="https://github.com/jacksoncurrie">Jackson</a>
    </footer>
    <script>
      import {
        getTripBaseForInstant,
        getTripDateKey
      } from "../lib/trip-location.mjs";

      window.addEventListener("load", () => {
        const leaflet = Reflect.get(window, "L");
        if (!leaflet) return;

        const tripMapEl = document.getElementById("trip-map");
        if (!tripMapEl) return;

        const tripMap = leaflet.map(tripMapEl, {
          attributionControl: true,
          dragging: false,
          scrollWheelZoom: false,
          doubleClickZoom: false,
          boxZoom: false,
          keyboard: false,
          tap: false,
          touchZoom: false,
          zoomControl: false
        });

        leaflet.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 18,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(tripMap);

        tripMap.setView([45.64, -63.0], 6);

        const initialTripBase = getTripBaseForInstant();
        const tripBaseMarker = leaflet.marker(
          [initialTripBase.lat, initialTripBase.lon],
          {
            title: `Today's trip base: ${initialTripBase.name}`,
            alt: `Today's trip base: ${initialTripBase.name}`
          }
        ).addTo(tripMap);

        tripBaseMarker.bindPopup(
          `<strong>Today's trip base</strong><br>${initialTripBase.name}`
        );

        let displayedTripBase = initialTripBase.name;

        const updateTripBase = () => {
          const now = new Date();
          const tripBase = getTripBaseForInstant(now);

          tripMapEl.dataset.tripBase = tripBase.name;
          tripMapEl.dataset.tripDate = getTripDateKey(now);
          tripMapEl.setAttribute(
            "aria-label",
            `Map showing today's planned trip base: ${tripBase.name}`
          );

          if (tripBase.name === displayedTripBase) return;

          tripBaseMarker.setLatLng([tripBase.lat, tripBase.lon]);
          tripBaseMarker.setPopupContent(
            `<strong>Today's trip base</strong><br>${tripBase.name}`
          );
          const markerLabel = `Today's trip base: ${tripBase.name}`;
          const markerElement = tripBaseMarker.getElement();
          tripBaseMarker.options.title = markerLabel;
          tripBaseMarker.options.alt = markerLabel;
          markerElement?.setAttribute("title", markerLabel);
          markerElement?.setAttribute("alt", markerLabel);
          displayedTripBase = tripBase.name;
        };

        updateTripBase();
        window.setInterval(updateTripBase, 60_000);
      });
    </script>
  </body>
</html>
