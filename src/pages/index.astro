---
import "../styles/global.css";

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

const withBase = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;
const placeHref = (name: string) => withBase(`/places/#${slugify(name)}`);

const placeLabels: Record<string, string> = {
  "Old Town Lunenburg": "Lunenburg",
  "Hirtle's Beach and Gaff Point": "Hirtle's Beach",
  "Cape Split Provincial Park": "Cape Split",
  "Fundy National Park and Alma": "Fundy National Park",
  "St. Martins sea caves": "St. Martins",
  "Fundy Trail Provincial Park": "Fundy Trail",
  "Prince Edward Island National Park: Cavendish, North Rustico, Brackley, Dalvay": "Prince Edward Island National Park",
  "Greenwich, Prince Edward Island National Park": "Greenwich",
  "Orwell Corner Historic Village": "Orwell Corner",
  "Northumberland Ferry: Caribou to Wood Islands": "Northumberland Ferry",
  "Pleasant Bay whale watching and west Cabot Trail base": "Pleasant Bay",
  "Ingonish, Middle Head, and Green Cove": "Ingonish"
};

const timeline = [
  {
    date: "Thu 23 Jul",
    title: "Arrive in Halifax",
    details: [
      "Air Canada 2071, Toronto to Halifax, 06:40-09:49. Personal item only.",
      "Pick up Enterprise compact crossover at 10:00 from the airport parking garage.",
      "Stay: King's College, night 1 of 2. Check-in after 15:00."
    ],
    places: ["Halifax"]
  },
  {
    date: "Fri 24 Jul",
    title: "Halifax and South Shore options",
    details: [
      "Stay: King's College, night 2 of 2.",
      "Use Halifax as the base for Peggy's Cove, Lunenburg, Blue Rocks, or Hirtle's Beach."
    ],
    places: [
      "Peggy's Cove",
      "Old Town Lunenburg",
      "Blue Rocks",
      "Hirtle's Beach and Gaff Point"
    ]
  },
  {
    date: "Sat 25 Jul",
    title: "Cape Split, then Moncton",
    details: [
      "Check out of King's College by 11:00.",
      "Hike Cape Split, then continue to Moncton.",
      "Stay: Glory Inn Downtown Moncton, night 1 of 2. Check-in after 15:00."
    ],
    places: ["Cape Split Provincial Park", "Joggins Fossil Cliffs"]
  },
  {
    date: "Sun 26 Jul",
    title: "Bay of Fundy coast day from Moncton",
    details: [
      "Fundy day from Moncton; pick stops based on tides and weather.",
      "Stay: Glory Inn Downtown Moncton, night 2 of 2."
    ],
    places: [
      "Fundy National Park and Alma",
      "Hopewell Rocks",
      "Cape Enrage",
      "St. Martins sea caves",
      "Fundy Trail Provincial Park"
    ]
  },
  {
    date: "Mon 27 Jul",
    title: "Moncton to Charlottetown",
    details: [
      "Check out of Glory Inn Downtown Moncton by 11:00.",
      "Move from Moncton to Charlottetown via the Confederation Bridge.",
      "Add Victoria-by-the-Sea as the scenic stop if timing works.",
      "Stay: Glendenning Hall, night 1 of 3. Check-in after 16:00."
    ],
    places: ["Victoria-by-the-Sea"]
  },
  {
    date: "Tue 28 Jul",
    title: "Charlottetown base",
    details: [
      "Stay: Glendenning Hall, night 2 of 3. Breakfast, Wi-Fi, and parking included.",
      "Keep this mostly local around Charlottetown."
    ],
    places: ["Charlottetown"]
  },
  {
    date: "Wed 29 Jul",
    title: "Prince Edward Island National Park",
    details: [
      "Stay: Glendenning Hall, night 3 of 3.",
      "Use the day around Prince Edward Island National Park and Greenwich."
    ],
    places: [
      "Prince Edward Island National Park: Cavendish, North Rustico, Brackley, Dalvay",
      "Greenwich, Prince Edward Island National Park"
    ]
  },
  {
    date: "Thu 30 Jul",
    title: "Ferry to Nova Scotia, then Margaree Valley",
    details: [
      "Check in at Wood Islands ferry terminal by 07:50.",
      "Ferry 2507993: Wood Islands to Caribou, departs 08:30.",
      "Morning stop in New Glasgow after the crossing.",
      "Stay: The Normaway Inn Cabins & Suites, night 1 of 3. Check-in after 15:00."
    ],
    places: [
      "Orwell Corner Historic Village",
      "Northumberland Ferry: Caribou to Wood Islands"
    ]
  },
  {
    date: "Fri 31 Jul",
    title: "Pleasant Bay from Margaree Valley",
    details: [
      "Stay: The Normaway Inn Cabins & Suites, night 2 of 3.",
      "Pleasant Bay is the nearby target for this day."
    ],
    places: ["Pleasant Bay whale watching and west Cabot Trail base"]
  },
  {
    date: "Sat 01 Aug",
    title: "Skyline Trail from Margaree Valley",
    details: [
      "Skyline Trail from Margaree Valley.",
      "Stay: The Normaway Inn Cabins & Suites, night 3 of 3."
    ],
    places: ["Skyline Trail"]
  },
  {
    date: "Sun 02 Aug",
    title: "Cape Breton to Halifax, then fly home",
    details: [
      "Early scenic drive via Ingonish, with only short stops.",
      "Return Enterprise car at Halifax International Airport by 15:30.",
      "Air Canada 2043, Halifax to Toronto, 17:05-18:30."
    ],
    places: ["Ingonish, Middle Head, and Green Cove"]
  }
];

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Timeline planner for a Toronto to Halifax trip from July 23 to August 2, 2026."
    />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    />
    <script
      is:inline
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      defer
    ></script>
    <title>Trip Planner</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label="Trip Planner home">
        Trip Planner
      </a>
      <nav aria-label="Primary navigation">
        <a href={withBase("/")} aria-current="page">Plan</a>
        <a href={withBase("/places/")}>Places</a>
      </nav>
    </header>

    <main class="planner-page">
      <section class="page-hero planner-hero">
        <div>
          <h1>
            <span>Trip to Atlantic Canada</span>
          </h1>
          <p>
            The timeline for the trip, with the fixed bookings, travel days,
            stays, and useful details for each day.
          </p>
        </div>
      </section>

      <section class="map-section planner-map-section" aria-label="Map of Atlantic Canada trip area">
        <div class="map-shell">
          <div id="trip-map" aria-label="Static map of Atlantic Canada"></div>
        </div>
      </section>

      <section class="section after-map-section timeline-section" id="timeline" aria-label="Trip timeline">
        <ol class="timeline trip-timeline">
          {timeline.map((item) => (
            <li>
              <time>{item.date}</time>
              <div>
                <div class="timeline-title-row">
                  <h3>{item.title}</h3>
                </div>
                <ul>
                  {item.details.map((detail) => <li>{detail}</li>)}
                </ul>
                {item.places.length > 0 && (
                  <div class="timeline-place-links" aria-label={`Places for ${item.date}`}>
                    {item.places.map((place) => (
                      <a href={placeHref(place)}>{placeLabels[place] ?? place}</a>
                    ))}
                  </div>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>

    </main>
    <footer class="site-footer">
      <a href="https://github.com/jacksoncurrie/atlantic-trip-planner">Trip Planner</a>{" "}
      made by{" "}
      <a href="https://github.com/jacksoncurrie">Jackson</a>
    </footer>
    <script is:inline>
      window.addEventListener("load", () => {
        if (!window.L) return;

        const tripMapEl = document.getElementById("trip-map");
        if (!tripMapEl) return;

        const tripMap = L.map(tripMapEl, {
          attributionControl: true,
          dragging: false,
          scrollWheelZoom: false,
          doubleClickZoom: false,
          boxZoom: false,
          keyboard: false,
          tap: false,
          touchZoom: false,
          zoomControl: false
        });

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 18,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(tripMap);

        tripMap.setView([45.64, -63.0], 6);
      });
    </script>
  </body>
</html>
