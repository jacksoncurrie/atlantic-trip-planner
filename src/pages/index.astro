---
import "../styles/global.css";

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

const withBase = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;
const placeHref = (name: string) => withBase(`/places/#${slugify(name)}`);
const foodHref = (name: string) => withBase(`/food/#${slugify(name)}`);

const placeLabels: Record<string, string> = {
  "Old Town Lunenburg": "Lunenburg",
  "Hirtle's Beach and Gaff Point": "Hirtle's Beach",
  "Cape Split Provincial Park": "Cape Split",
  "Fundy National Park and Alma": "Fundy National Park",
  "St. Martins sea caves": "St. Martins",
  "Fundy Trail Provincial Park": "Fundy Trail",
  "Prince Edward Island National Park: Cavendish, North Rustico, Brackley, Dalvay": "Prince Edward Island National Park",
  "Greenwich, Prince Edward Island National Park": "Greenwich",
  "Orwell Corner Historic Village": "Orwell Corner",
  "Northumberland Ferry: Caribou to Wood Islands": "Northumberland Ferry",
  "Pleasant Bay whale watching and west Cabot Trail base": "Pleasant Bay",
  "Ingonish, Middle Head, and Green Cove": "Ingonish"
};

