    gallery: [
          "/assets/ideas/curated/orwell-corner-historic-village-1.jpg",
          "/assets/ideas/curated/orwell-corner-historic-village-2.jpg",
          "/assets/ideas/curated/orwell-corner-historic-village-3.jpg",
          "/assets/ideas/curated/orwell-corner-historic-village-4.jpg"
    ],
    source: "https://www.peimuseum.ca/visit/orwell-corner-historic-village",
    description:
      "A 1890s Prince Edward Island village and working-farm museum with animals, a general store, schoolhouse, church, blacksmithing, wagon rides, and farm programming.",
    whyGo:
      "It is practical rather than precious: a specific Prince Edward Island history stop near the Charlottetown-to-Wood-Islands corridor.",
    july:
      "The Prince Edward Island Museum lists July and August 2026 hours as seven days a week, 8:30am-4:30pm, making it easy to slot into a ferry-side day.",
    activities: ["Historic village", "Farm animals", "Blacksmith shop", "Wagon ride", "Ferry corridor"]
  }
];

const provinceIdeaOrder: Record<string, string[]> = {
  "Nova Scotia": [
    "Halifax waterfront, Citadel, North End, and Dartmouth ferry",
    "Peggy's Cove",
    "Old Town Lunenburg",
    "Blue Rocks",
    "Hirtle's Beach and Gaff Point",
    "Cape Split Provincial Park",
    "Joggins Fossil Cliffs",
    "Pleasant Bay whale watching and west Cabot Trail base",
    "Skyline Trail",
    "Ingonish, Middle Head, and Green Cove"
  ],
  "New Brunswick": [
    "Fundy National Park and Alma",
    "Hopewell Rocks",
    "Cape Enrage",
    "St. Martins sea caves",
    "Fundy Trail Provincial Park"
  ],
  "Prince Edward Island": [
    "Charlottetown",
    "Prince Edward Island National Park: Cavendish, North Rustico, Brackley, Dalvay",
    "Greenwich, Prince Edward Island National Park",
    "Victoria-by-the-Sea",
    "Orwell Corner Historic Village",
    "Northumberland Ferry: Caribou to Wood Islands"
  ]
};

const groupedIdeas = ideas.reduce<Record<string, typeof ideas>>((groups, idea) => {
  groups[idea.province] = groups[idea.province] ?? [];
  groups[idea.province].push(idea);
  return groups;
}, {});

Object.entries(groupedIdeas).forEach(([province, provinceIdeas]) => {
  const order = provinceIdeaOrder[province] ?? [];
  groupedIdeas[province] = provinceIdeas.toSorted((a, b) => {
    const aIndex = order.indexOf(a.name);
    const bIndex = order.indexOf(b.name);
    return (aIndex === -1 ? Number.MAX_SAFE_INTEGER : aIndex) -
      (bIndex === -1 ? Number.MAX_SAFE_INTEGER : bIndex);
  });
});

