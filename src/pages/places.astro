const provinceIdeaOrder: Record<string, string[]> = {
  "Nova Scotia": [
    "Halifax",
    "Peggy's Cove",
    "Old Town Lunenburg",
    "Blue Rocks",
    "Hirtle's Beach and Gaff Point",
    "Cape Split Provincial Park",
    "Joggins Fossil Cliffs",
    "Pleasant Bay whale watching and west Cabot Trail base",
    "Skyline Trail",
    "Ingonish, Middle Head, and Green Cove"
  ],
  "New Brunswick": [
    "Fundy National Park and Alma",
    "Hopewell Rocks",
    "Cape Enrage",
    "St. Martins sea caves",
    "Fundy Trail Provincial Park"
  ],
  "Prince Edward Island": [
    "Charlottetown",
    "Prince Edward Island National Park: Cavendish, North Rustico, Brackley, Dalvay",
    "Greenwich, Prince Edward Island National Park",
    "Victoria-by-the-Sea",
    "Orwell Corner Historic Village",
    "Northumberland Ferry: Caribou to Wood Islands"
  ]
};

const provinceSummaries: Record<string, string> = {
  "Nova Scotia":
    "The core of the trip: Halifax, South Shore towns, Bay of Fundy stops, and the Cape Breton hiking days.",
  "New Brunswick":
    "Fundy-side options from the Moncton base, mostly tide-driven coast, park roads, cliffs, and short walks.",
  "Prince Edward Island":
    "Island base days around Charlottetown, north-shore beaches, Greenwich dunes, small villages, and the ferry crossing."
};

const groupedIdeas = ideas.reduce<Record<string, typeof ideas>>((groups, idea) => {
  groups[idea.province] = groups[idea.province] ?? [];
  groups[idea.province].push(idea);
  return groups;
}, {});

Object.entries(groupedIdeas).forEach(([province, provinceIdeas]) => {
  const order = provinceIdeaOrder[province] ?? [];
  groupedIdeas[province] = provinceIdeas.toSorted((a, b) => {
    const aIndex = order.indexOf(a.name);
    const bIndex = order.indexOf(b.name);
    return (aIndex === -1 ? Number.MAX_SAFE_INTEGER : aIndex) -
      (bIndex === -1 ? Number.MAX_SAFE_INTEGER : bIndex);
  });
});

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Place catalog for a July 2026 Atlantic Canada road trip, with photos, location maps, short descriptions, and time estimates."
    />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    />
    <script
      is:inline
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      defer
    ></script>
    <title>Trip Planner Places</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label="Trip Planner home">
        Trip Planner
      </a>
      <nav aria-label="Primary navigation">
        <a href={withBase("/")}>Plan</a>
        <a href={withBase("/places/")} aria-current="page">Places</a>
      </nav>
    </header>

    <main class="places-page">
      <section class="page-hero">
        <div>
          <h1>Places to visit</h1>
          <p>
            A simple list of the trip ideas, with where each place sits on the
            map, a few photos, and the key notes for deciding what to do.
          </p>
        </div>
      </section>

      <section class="map-section places-overview-section" aria-labelledby="ideas-map-title">
        <h2 id="ideas-map-title" class="visually-hidden">All places map</h2>
        <div class="map-shell">
          <div id="ideas-overview-map" aria-label="Interactive map of all trip places"></div>
        </div>
      </section>

      {Object.entries(groupedIdeas).map(([province, provinceIdeas], provinceIndex) => (
        <section
          class={`section idea-section ${provinceIndex === 0 ? "after-map-section" : ""}`}
          id={province.toLowerCase().replaceAll(" ", "-")}
          aria-labelledby={`${province}-title`}
        >
          <div class="section-header">
            <div>
              <h2 id={`${province}-title`}>{province}</h2>
            </div>
            <p>{provinceSummaries[province]}</p>
          </div>

          <div class="idea-grid">
            {provinceIdeas.map((idea) => {
              const photos = idea.gallery;
              return (
                <article
                  class="idea-card"
                  id={slugify(idea.name)}
                  data-lat={idea.lat}
                  data-lon={idea.lon}
                  data-name={idea.name}
                >
                  <div class="idea-title-row">
                    <h3>{idea.name}</h3>
                  </div>

                  <div class="idea-gallery" aria-label={`${idea.name} photo gallery`}>
                    {photos.map((photo, index) => (
                      <figure>
                        <img src={withBase(photo)} alt={`${idea.name} view ${index + 1}`} />
                      </figure>
                    ))}
                  </div>
                  <div class="idea-body">
                    <div
                      class="idea-leaflet-map"
                      aria-label={`OpenStreetMap pin for ${idea.name}`}
                    >
                    </div>

                    <dl class="idea-facts">
                      <div>
                        <dt>Type</dt>
                        <dd>{idea.type}</dd>
                      </div>
                      <div>
                        <dt>Time needed</dt>
                        <dd>{idea.timeNeeded}</dd>
                      </div>
                    </dl>

                    <div class="idea-copy">
                      <h4>Description</h4>
                      <p>{idea.description}</p>
                    </div>

                    <a href={idea.source} target="_blank" rel="noreferrer">Source / details</a>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      ))}

    </main>
    <footer class="site-footer">
      <a href="https://github.com/jacksoncurrie/atlantic-trip-planner">Trip Planner</a>
      made by
      <a href="https://github.com/jacksoncurrie">Jackson</a>
    </footer>
    <script is:inline>
      window.addEventListener("load", () => {
        if (!window.L) return;

        const ideaCards = Array.from(document.querySelectorAll(".idea-card"));
        const stops = ideaCards
          .map((card) => ({
            name: card.dataset.name || "Trip idea",
            lat: Number(card.dataset.lat),
            lon: Number(card.dataset.lon)
          }))
          .filter((stop) => Number.isFinite(stop.lat) && Number.isFinite(stop.lon));

        const overviewEl = document.getElementById("ideas-overview-map");
        if (overviewEl && stops.length > 0) {
          const overview = L.map(overviewEl, {
            attributionControl: true,
            dragging: false,
            scrollWheelZoom: false,
            doubleClickZoom: false,
            boxZoom: false,
            keyboard: false,
            tap: false,
            touchZoom: false,
            zoomControl: true
          });

          L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 18,
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
          }).addTo(overview);

          stops.forEach((stop) => {
            L.marker([stop.lat, stop.lon]).addTo(overview).bindPopup(stop.name);
          });

          overview.setView([45.64, -63.0], 6);
        }

        document.querySelectorAll(".idea-card").forEach((card) => {
          const mapEl = card.querySelector(".idea-leaflet-map");
          const lat = Number(card.dataset.lat);
          const lon = Number(card.dataset.lon);
          const name = card.dataset.name || "Trip idea";

          if (!mapEl || !Number.isFinite(lat) || !Number.isFinite(lon)) return;

          const map = L.map(mapEl, {
            attributionControl: false,
            dragging: false,
            scrollWheelZoom: false,
            doubleClickZoom: false,
            boxZoom: false,
            keyboard: false,
            tap: false,
            touchZoom: false,
            zoomControl: false
          }).setView([lat, lon], 6);

          L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 18
          }).addTo(map);

          L.marker([lat, lon]).addTo(map).bindPopup(name);
        });
      });
    </script>
  </body>
</html>
