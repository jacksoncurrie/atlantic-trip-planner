<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Place catalog for a July 2026 Atlantic Canada road trip, with photos, location maps, activity notes, and time estimates."
    />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    />
    <script
      is:inline
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      defer
    ></script>
    <title>Atlantic Trip Places</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label="Atlantic Trip Planner home">
        Atlantic Trip Planner
      </a>
      <nav aria-label="Primary navigation">
        <a href={withBase("/")}>Planner</a>
        <a href={withBase("/places/")} aria-current="page">Places</a>
      </nav>
    </header>

    <main class="ideas-page">
      <section class="research-hero">
        <div>
          <h1>Places to visit</h1>
          <p>
            A simple list of the trip ideas, with where each place sits on the
            map, a few photos, and the key notes for deciding what to do.
          </p>
        </div>
      </section>

      <section class="section" aria-labelledby="ideas-map-title">
        <div class="section-header">
          <div>
            <p class="section-label">All places map</p>
            <h2 id="ideas-map-title">Where everything sits across the region</h2>
          </div>
          <p>
            This overview uses the same Leaflet / OpenStreetMap setup as the
            planner map. It pins every place so you can see the spread before
            browsing the individual cards.
          </p>
        </div>
        <div class="map-shell">
          <div id="ideas-overview-map" aria-label="Interactive map of all trip places"></div>
        </div>
      </section>

      {Object.entries(groupedIdeas).map(([province, provinceIdeas]) => (
        <section
          class="section idea-section"
          id={province.toLowerCase().replaceAll(" ", "-")}
          aria-labelledby={`${province}-title`}
        >
          <div class="section-header">
            <div>
              <p class="section-label">Places</p>
              <h2 id={`${province}-title`}>{province}</h2>
            </div>
            <p>
            Browse these as options, not a fixed route. The point is to find
              the strongest matches before turning them into a schedule.
            </p>
          </div>

          <div class="idea-grid">
            {provinceIdeas.map((idea) => {
              const photos = idea.gallery;
              return (
                <article
                  class="idea-card"
                  id={slugify(idea.name)}
                  data-lat={idea.lat}
                  data-lon={idea.lon}
                  data-name={idea.name}
                >
                  <div class="idea-gallery" aria-label={`${idea.name} photo gallery`}>
                    {photos.map((photo, index) => (
                      <figure class={index === 0 ? "feature-photo" : "support-photo"}>
                        <img src={withBase(photo)} alt={`${idea.name} view ${index + 1}`} />
                      </figure>
                    ))}
                  </div>
                  <div class="idea-body">
                    <div class="idea-title-row">
                      <div>
                        <p class="section-label">{idea.region}</p>
                        <h3>{idea.name}</h3>
                      </div>
                      <span>{idea.priority}</span>
                    </div>

                    <div
                      class="idea-leaflet-map"
                      aria-label={`OpenStreetMap pin for ${idea.name}`}
                    >
                    </div>

                    <dl class="idea-facts">
                      <div>
                        <dt>Type</dt>
                        <dd>{idea.type}</dd>
                      </div>
                      <div>
                        <dt>Time needed</dt>
                        <dd>{idea.timeNeeded}</dd>
                      </div>
                    </dl>

                    <div class="idea-copy">
                      <h4>What it is</h4>
                      <p>{idea.description}</p>
                      <h4>Why go</h4>
                      <p>{idea.whyGo}</p>
                      <h4>Late July / early August</h4>
                      <p>{idea.july}</p>
                    </div>

                    <div class="activity-list" aria-label={`Activities for ${idea.name}`}>
                      {idea.activities.map((activity) => <span>{activity}</span>)}
                    </div>

                    <a href={idea.source} target="_blank" rel="noreferrer">Source / details</a>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      ))}

      <section class="section sources" aria-labelledby="sources-title">
        <h2 id="sources-title">Source links</h2>
        <div>
          {sources.map(([label, url]) => (
            <a href={url} target="_blank" rel="noreferrer">{label}</a>
          ))}
        </div>
      </section>
    </main>
    <footer class="site-footer">Atlantic Trip Planner</footer>
    <script is:inline>
      window.addEventListener("load", () => {
        if (!window.L) return;

        const ideaCards = Array.from(document.querySelectorAll(".idea-card"));
        const stops = ideaCards
          .map((card) => ({
            name: card.dataset.name || "Trip idea",
            lat: Number(card.dataset.lat),
            lon: Number(card.dataset.lon)
          }))
          .filter((stop) => Number.isFinite(stop.lat) && Number.isFinite(stop.lon));

        const overviewEl = document.getElementById("ideas-overview-map");
        if (overviewEl && stops.length > 0) {
          const overview = L.map(overviewEl, {
            scrollWheelZoom: false
          });

          L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 18,
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
          }).addTo(overview);

          const bounds = L.latLngBounds(stops.map((stop) => [stop.lat, stop.lon]));

          stops.forEach((stop) => {
            L.marker([stop.lat, stop.lon]).addTo(overview).bindPopup(stop.name);
          });

          overview.fitBounds(bounds, {
            padding: [34, 34]
          });
        }

        document.querySelectorAll(".idea-card").forEach((card) => {
          const mapEl = card.querySelector(".idea-leaflet-map");
          const lat = Number(card.dataset.lat);
          const lon = Number(card.dataset.lon);
          const name = card.dataset.name || "Trip idea";

          if (!mapEl || !Number.isFinite(lat) || !Number.isFinite(lon)) return;

          const map = L.map(mapEl, {
            attributionControl: false,
            dragging: false,
            scrollWheelZoom: false,
            doubleClickZoom: false,
            boxZoom: false,
            keyboard: false,
            tap: false,
            touchZoom: false,
            zoomControl: false
          }).setView([lat, lon], 6);

          L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 18
          }).addTo(map);

          L.marker([lat, lon]).addTo(map).bindPopup(name);
        });
      });
    </script>
  </body>
</html>
